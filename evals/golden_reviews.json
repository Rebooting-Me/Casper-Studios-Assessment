{
  "version": "1.0",
  "description": "Golden set: 50 hand-labeled (review -> expected edits) fixtures for Layer 1 (extraction) of the recipe enhancement eval. Each review is anchored to a concrete recipe so deterministic groundedness checks can run without external lookups.",
  "matcher_notes": {
    "edit_match_key": "(modification_type, target, operation, normalized(replace|add)) with token-set similarity >= 0.7",
    "find_anchor_lenient": "For add_after operations, the find anchor may be any line; primary match is on the added content.",
    "quantity_normalization": "'0.5' == '1/2' == 'half'; case-insensitive; whitespace collapsed.",
    "multi_intent_on_same_line": "When a single user statement modifies multiple aspects of one line (e.g. 'doubled the cheese and used gruyere instead'), edits are expressed as separate atomic operations sharing the same find. Matcher should treat the modification as satisfied if the final line reflects all intents."
  },
